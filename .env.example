# LegalEaseFile Environment Variables - $38.7M Revenue Platform
# For Render deployment - set these in Render dashboard

# Required for deployment
NODE_ENV=production
PORT=10000

# Database - Auto-filled by Render PostgreSQL service
DATABASE_URL=postgresql://username:password@hostname:port/database

# Authentication - Generate a secure random string (32+ characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-random-string

# Payment Processing (Optional - can add later)
# Get from stripe.com dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# AI Features (Optional - can add later)
# Get from openai.com
OPENAI_API_KEY=sk-your-openai-api-key-here

# MINIMAL SETUP FOR FREE DEPLOYMENT:
# 1. NODE_ENV=production
# 2. PORT=10000
# 3. DATABASE_URL=(auto-filled by Render)
# 4. JWT_SECRET=(generate random 32+ char string)
ISSUER_URL=https://replit.com/oidc
REPL_ID=your-repl-id
SESSION_SECRET=your-secure-session-secret

# Payment Processing
STRIPE_SECRET_KEY=sk_live_or_test_your_stripe_key

# AI Services
OPENAI_API_KEY=your-openai-api-key

# External Services
AIRTABLE_API_KEY=your-airtable-api-key
AIRTABLE_BASE_ID=your-airtable-base-id

# Server Configuration
NODE_ENV=production
PORT=5000